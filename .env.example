# --- 1. CORE SYSTEM CONFIG ---
APP_ENV=production
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-app.com

# --- 2. DATABASE CONFIG ---
# For local dev: postgresql://postgres:postgress_secure_pwd@localhost:5432/trading_db
# For Docker: postgresql://postgres:postgress_secure_pwd@postgres:5432/trading_db
DATABASE_URL=postgresql://postgres:REPLACE_ME_SECURE_PASSWORD@postgres:5432/trading_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_ME_SECURE_PASSWORD
POSTGRES_DB=trading_db

# --- 3. SECURITY & AUTH ---
# Generate a strong 32-character string
JWT_SECRET_KEY=REPLACE_ME_SECRET_KEY
GOOGLE_CLIENT_ID=REPLACE_ME_GOOGLE_CLIENT_ID

# --- 4. MARKET DATA API KEYS ---
ALPHAVANTAGE_API_KEY=REPLACE_ME
NEWS_API_KEY=REPLACE_ME

# --- 5. REDIS CACHE ---
REDIS_URL=redis://redis:6379/0

# --- 6. FRONTEND (Vite Prefix Required) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_AUTH_API_URL=http://localhost:8001
VITE_GOOGLE_CLIENT_ID=REPLACE_ME_GOOGLE_CLIENT_ID
